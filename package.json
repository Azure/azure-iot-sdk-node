{
	"scripts": {
		"npmlockrefresh": "npm i --package-lock-only",
		"codespaceinstall": "(cd device/samples/javascript && npm install & cd ../../../) && (cd device/samples/javascript/pnp && npm install & cd ../../../../) && (cd device/samples/typescript && npm install && npm run build)"
	},
	"devDependencies": {
		"lerna": "^9.0.7",
		"mocha": "^10.7.0",
		"typescript": "^5.5.0",
		"@types/node": "^18.19.0"
	},
	"overrides": {
		"typescript": "^5.5.0",
		"@types/node": "^18.19.0",
		"serialize-javascript": ">=7.0.5"
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"husky": {
		"hooks": {
			"commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
		}
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		],
		"rules": {
			"header-max-length": [
				0,
				"always",
				150
			]
		}
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"dependencies": {
		"eslint-plugin-security": "^1.5.0",
		"node-gyp": "^12.2.0"
	}
}
