{
	"workspaces": [
		"build/tools",
		"common/core",
		"common/transport/*",
		"device/core",
		"device/samples",
		"device/samples/javascript",
		"device/samples/typescript",
		"device/samples/helpers/device-twin-service",
		"device/transport/*",
		"provisioning/*",
		"provisioning/transport/*",
		"provisioning/device/samples",
		"provisioning/device/ts-samples",
		"provisioning/service/samples",
		"security/*",
		"sdklab/longhaultests",
		"sdklab/mean_time_recovery",
		"sdklab/stress_fault",
		"e2etests",
		"ts-e2e",
		"stresstests"
	],
	"scripts": {
		"npmlockrefresh": "npm i --package-lock-only",
		"codespaceinstall": "(cd device/samples/javascript && npm install & cd ../../../) && (cd device/samples/javascript/pnp && npm install & cd ../../../../) && (cd device/samples/typescript && npm install && npm run build)"
	},
	"devDependencies": {
		"@types/node": "^18.19.0",
		"lerna": "^9.0.7",
		"mocha": "^10.7.0",
		"typescript": "^5.5.0"
	},
	"overrides": {
		"typescript": "^5.5.0",
		"@types/node": "^18.19.0",
		"serialize-javascript": ">=7.0.5",
		"es5-ext": ">=0.10.63",
		"xml2js": ">=0.5.0",
		"axios": ">=1.7.9",
		"@azure/identity": ">=4.2.1",
		"jshint": {
			"minimatch": "3.1.4"
		}
	},
	"engines": {
		"node": ">=18.0.0"
	},
	"husky": {
		"hooks": {
			"commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
		}
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		],
		"rules": {
			"header-max-length": [
				0,
				"always",
				150
			]
		}
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"dependencies": {
		"@azure/ms-rest-js": "^2.7.0",
		"@opencensus/web-types": "^0.0.7",
		"eslint-plugin-security": "^1.5.0",
		"node-gyp": "^12.2.0"
	}
}
